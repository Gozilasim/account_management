# Created at: 2026-05-11 01:39
# Updated at: 2026-05-12 00:31
# Description: Example root environment variables for the backend Portal service.

# Local default uses SQLite at project-root data/portal.db.
# Docker compose overrides this to sqlite:////app/data/portal.db inside the container.
DATABASE_URL=sqlite:///./data/portal.db

# Backend reads this root .env even when commands are run from backend/.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Public URLs are optional. If empty, they are derived from host/port above.
# Set these explicitly in production or when using a custom domain.
BACKEND_URL=
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
FRONTEND_URL=
CORS_ORIGINS=

SESSION_COOKIE_NAME=portal_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_MINUTES=10080
TRUST_PROXY_HEADERS=false

MFA_ISSUER=My Portal
PASSWORD_MIN_LENGTH=8
PASSWORD_RESET_DELIVERY=dev_log
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
AVATAR_MAX_BYTES=5242880

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Production should provide a stable RSA private key.
# OIDC_PRIVATE_KEY_PEM=
# OIDC_PRIVATE_KEY_PATH=
OIDC_KEY_ID=portal-dev-key
